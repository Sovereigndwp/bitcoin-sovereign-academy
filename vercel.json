{
  "cleanUrls": true,
  "installCommand": "npm install",
  "buildCommand": "",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "bitcoin-sovereign-academy.vercel.app"
        }
      ],
      "destination": "https://bitcoinsovereign.academy/:path*",
      "permanent": true
    },
    {
      "source": "/semana-:week/:rest*",
      "destination": "/programa-colombia/semana-:week/:rest*",
      "permanent": false
    },
    {
      "source": "/semana-:week",
      "destination": "/programa-colombia/semana-:week",
      "permanent": false
    },
    {
      "source": "/semana-:week/",
      "destination": "/programa-colombia/semana-:week/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/interactive-demos/:demo",
      "destination": "/interactive-demos/:demo/index.html"
    },
    {
      "source": "/interactive-demos/:demo/",
      "destination": "/interactive-demos/:demo/index.html"
    },
    {
      "source": "/paths",
      "destination": "/paths/index.html"
    },
    {
      "source": "/paths/",
      "destination": "/paths/index.html"
    },
    {
      "source": "/paths/:path",
      "destination": "/paths/:path/index.html"
    },
    {
      "source": "/paths/:path/",
      "destination": "/paths/:path/index.html"
    },
    {
      "source": "/deep-dives",
      "destination": "/deep-dives/index.html"
    },
    {
      "source": "/deep-dives/",
      "destination": "/deep-dives/index.html"
    },
    {
      "source": "/deep-dives/:section",
      "destination": "/deep-dives/:section/index.html"
    },
    {
      "source": "/deep-dives/:section/",
      "destination": "/deep-dives/:section/index.html"
    },
    {
      "source": "/institutional",
      "destination": "/institutional/index.html"
    },
    {
      "source": "/institutional/",
      "destination": "/institutional/index.html"
    },
    {
      "source": "/institutional/:page",
      "destination": "/institutional/:page.html"
    },
    {
      "source": "/institutional/:page/",
      "destination": "/institutional/:page.html"
    },
    {
      "source": "/institutional/wealth-advisors/bitcoin-advisor-certification",
      "destination": "/institutional/wealth-advisors/bitcoin-advisor-certification/index.html"
    },
    {
      "source": "/institutional/wealth-advisors/bitcoin-advisor-certification/",
      "destination": "/institutional/wealth-advisors/bitcoin-advisor-certification/index.html"
    },
    {
      "source": "/institutional/wealth-advisors/bitcoin-advisor-certification/:day/:module",
      "destination": "/institutional/wealth-advisors/bitcoin-advisor-certification/:day/:module.html"
    },
    {
      "source": "/institutional/wealth-advisors/bitcoin-advisor-certification/resources/:resource",
      "destination": "/institutional/wealth-advisors/bitcoin-advisor-certification/resources/:resource.html"
    },
    {
      "source": "/youth-families",
      "destination": "/youth-families/index.html"
    },
    {
      "source": "/youth-families/",
      "destination": "/youth-families/index.html"
    },
    {
      "source": "/youth-families/:week",
      "destination": "/youth-families/:week/index.html"
    },
    {
      "source": "/youth-families/:week/",
      "destination": "/youth-families/:week/index.html"
    },
    {
      "source": "/programa-colombia",
      "destination": "/programa-colombia/index.html"
    },
    {
      "source": "/programa-colombia/",
      "destination": "/programa-colombia/index.html"
    },
    {
      "source": "/programa-colombia/:week",
      "destination": "/programa-colombia/:week/index.html"
    },
    {
      "source": "/programa-colombia/:week/",
      "destination": "/programa-colombia/:week/index.html"
    }
  ],
  "headers": [
    {
      "source": "/interactive-demos/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: https://*.supabase.co https://api.stripe.com https://api.coingecko.com https://mempool.space https://blockstream.info; frame-src https://js.stripe.com"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/paths/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: https://*.supabase.co https://api.stripe.com https://api.coingecko.com https://mempool.space https://blockstream.info; frame-src 'self' https://js.stripe.com"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://js.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: https://*.supabase.co https://api.stripe.com https://api.coingecko.com https://mempool.space https://blockstream.info; frame-src https://js.stripe.com"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
