{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitcoinsovereign.academy/schema/risk-output.schema.json",
  "title": "Risk Output (Exposure Map)",
  "description": "The result the audit produces. Uses classification, never a numeric score. All language is non-alarming and framed as flags and questions.",
  "type": "object",
  "required": ["primary_exposure_type", "disclaimer"],
  "additionalProperties": false,
  "properties": {
    "primary_exposure_type": { "type": "string", "enum": ["tax_visibility_issue", "estate_mismatch", "custody_concentration", "banking_fragility", "jurisdictional_concentration", "documentation_leak", "cross_border_family_gap", "advisor_coordination_gap", "business_governance_gap", "unknown_missing_information"] },
    "secondary_exposure_types": { "type": "array", "items": { "type": "string" } },
    "countries_involved": { "type": "array", "items": { "type": "string" } },
    "bitcoin_exposure_type": { "type": "array", "items": { "type": "string" } },
    "flags": {
      "type": "object",
      "description": "Per category, a list of plain-language flags with a state label.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["label", "state"],
          "properties": {
            "label": { "type": "string" },
            "state": { "type": "string", "enum": ["stable", "fragile", "concentrated", "unclear", "needs_review", "missing", "documented", "overexposed", "mismatch"] },
            "what_it_means": { "type": "string" },
            "why_it_matters": { "type": "string" },
            "what_not_to_do": { "type": "string" },
            "what_to_document_next": { "type": "string" }
          }
        }
      }
    },
    "professional_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["professional", "questions"],
        "properties": {
          "professional": { "type": "string", "enum": ["tax-counsel", "estate-attorney", "immigration-attorney", "corporate-counsel", "bitcoin-custody-specialist", "accountant", "family-office-advisor", "banking-specialist"] },
          "questions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "recommended_resources": { "type": "array", "items": { "$ref": "https://bitcoinsovereign.academy/schema/product-routing.schema.json#/$defs/resourceRef" } },
    "recommended_pathway": { "$ref": "https://bitcoinsovereign.academy/schema/product-routing.schema.json#/$defs/pathwayRef" },
    "result_confidence": { "type": "string", "enum": ["clear", "partial", "insufficient_information"], "description": "If the user skipped sections, the result is 'partial' or 'insufficient_information' and must say so." },
    "disclaimer": { "type": "string", "default": "This is not legal, tax, investment, or financial advice. It is a preparation document for a conversation with a qualified professional." }
  }
}
