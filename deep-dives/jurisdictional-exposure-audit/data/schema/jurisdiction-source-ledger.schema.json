{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitcoinsovereign.academy/schema/jurisdiction-source-ledger.schema.json",
  "title": "Jurisdiction Source Ledger",
  "description": "Central ledger of every source cited by any claim. Tier 4 sources may only be referenced by claims that exist to flag a research question; they may not be the sole support for a legal or tax conclusion.",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "ledger_version": { "type": "string", "default": "1.0" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "title", "url", "publisher", "source_type", "tier", "date_accessed"],
        "additionalProperties": false,
        "properties": {
          "source_id": { "type": "string", "description": "e.g. 'src-irs-da-faq'." },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "publisher": { "type": "string" },
          "source_type": { "type": "string", "enum": ["tax-authority", "financial-regulator", "securities-commodities-regulator", "central-bank", "legislation-legal-code", "court-decision", "oecd", "fatf", "eu-official", "treaty-framework", "accounting-firm", "law-firm", "policy-institution", "academic", "professional-association", "exchange-doc", "custodian-doc", "industry-report", "media", "crypto-policy-analysis", "blog", "forum", "social-media", "marketing"] },
          "tier": { "type": "integer", "minimum": 1, "maximum": 4 },
          "jurisdiction": { "type": "string", "description": "country_id, or 'global' for OECD/FATF etc." },
          "topic": { "type": "array", "items": { "type": "string" } },
          "publication_date": { "type": "string", "description": "ISO date or year, if known; omit if unknown." },
          "date_accessed": { "type": "string", "format": "date" },
          "summary": { "type": "string" },
          "relevant_sections": { "type": "string" },
          "reliability_notes": { "type": "string" },
          "archived_copy": { "type": "string", "description": "URL of an archived snapshot, if captured." },
          "used_by_claims": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
