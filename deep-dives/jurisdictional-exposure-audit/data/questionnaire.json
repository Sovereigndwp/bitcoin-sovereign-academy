{
  "$schema_ref": "./schema/audit-question.schema.json",
  "version": "1.0",
  "last_reviewed": "2026-06-16",
  "data_safety_notice": "Do not enter seed phrases, private keys, wallet addresses, exact balances, passwords, PINs, full legal names, passport or tax ID numbers, bank account numbers, or your exact home address. This audit works entirely with categories and ranges. Your answers stay on your device.",
  "sections": [
    {
      "section": "entry",
      "title": "Before you start",
      "questions": [
        {
          "id": "entry.ack",
          "section": "entry",
          "prompt": "This is an educational map, not legal or tax advice, and it never asks for secrets. Ready to begin?",
          "type": "boolean",
          "privacy_note": "Keep this private. Use categories, not exact figures.",
          "required": true
        }
      ]
    },
    {
      "section": "user_type",
      "title": "Where are you starting from?",
      "questions": [
        {
          "id": "ut.role",
          "section": "user_type",
          "prompt": "Which of these describe your situation? Choose all that apply.",
          "type": "multi_select",
          "required": true,
          "options": [
            { "value": "individual_holder", "label": "I own Bitcoin personally" },
            { "value": "advisor", "label": "I advise clients (attorney, CPA, planner, family office)" },
            { "value": "cross_border_family", "label": "My family spans more than one country" },
            { "value": "business_family_office", "label": "I own a business or run a family office" },
            { "value": "considering_relocation", "label": "I am considering changing countries" },
            { "value": "unsure", "label": "I am not sure. Help me map my exposure" }
          ]
        },
        {
          "id": "ut.amount_band",
          "section": "user_type",
          "prompt": "Roughly how would you describe the scale of what is at stake? Category only.",
          "help_text": "We never ask for an amount. This only helps shape the questions.",
          "type": "single_select",
          "options": [
            { "value": "less_than_life_changing", "label": "Less than life-changing" },
            { "value": "meaningful_savings", "label": "Meaningful savings" },
            { "value": "life_changing", "label": "A life-changing amount" },
            { "value": "business_treasury", "label": "Business treasury" },
            { "value": "family_wealth", "label": "Family wealth across people" },
            { "value": "prefer_not_to_say", "label": "Prefer not to say" }
          ]
        }
      ]
    },
    {
      "section": "jurisdiction_map",
      "title": "Your personal jurisdiction map",
      "questions": [
        {
          "id": "jm.countries",
          "section": "jurisdiction_map",
          "prompt": "Which countries are connected to your life in any way? Add each one.",
          "type": "country_multi_select",
          "required": true
        },
        {
          "id": "jm.roles",
          "section": "jurisdiction_map",
          "prompt": "For each country, which of these does it cover?",
          "help_text": "This is where mismatches usually hide. A country can hold your residence but not your heirs, or your bank but not your tax home.",
          "type": "per_country_roles",
          "options": [
            { "value": "residence", "label": "Where I live" },
            { "value": "citizenship", "label": "Citizenship" },
            { "value": "tax_residence", "label": "Tax residence" },
            { "value": "domicile", "label": "Domicile" },
            { "value": "employment", "label": "Employment / income" },
            { "value": "business", "label": "Business ownership" },
            { "value": "real_estate", "label": "Real estate" },
            { "value": "bank_account", "label": "Bank account" },
            { "value": "brokerage", "label": "Brokerage / investment account" },
            { "value": "retirement", "label": "Retirement account" },
            { "value": "insurance", "label": "Insurance" },
            { "value": "heirs", "label": "Heirs" },
            { "value": "spouse", "label": "Spouse / partner" },
            { "value": "legal_documents", "label": "Legal documents (will, POA)" },
            { "value": "attorney", "label": "Attorney" },
            { "value": "tax_advisor", "label": "Tax advisor" },
            { "value": "exchange", "label": "Bitcoin exchange account" },
            { "value": "custody_provider", "label": "Bitcoin custody provider" },
            { "value": "hardware_wallet_location", "label": "Hardware wallet is physically here" },
            { "value": "backup_location", "label": "A backup is physically here" },
            { "value": "trusted_helper", "label": "A trusted helper lives here" }
          ]
        }
      ]
    },
    {
      "section": "custody_map",
      "title": "Your Bitcoin ownership and custody map",
      "questions": [
        {
          "id": "cm.types",
          "section": "custody_map",
          "prompt": "Which forms of Bitcoin exposure do you have? Choose all that apply.",
          "type": "multi_select",
          "applies_when": { "user_type_any": ["individual_holder", "cross_border_family", "business_family_office", "considering_relocation", "unsure"] },
          "options": [
            { "value": "exchange", "label": "On an exchange" },
            { "value": "etf", "label": "A Bitcoin ETF" },
            { "value": "custodian", "label": "A custodian holds it" },
            { "value": "single_sig_hardware", "label": "Single-signature hardware wallet" },
            { "value": "mobile_wallet", "label": "Mobile wallet" },
            { "value": "lightning_wallet", "label": "Lightning wallet" },
            { "value": "diy_multisig", "label": "DIY multisig" },
            { "value": "collaborative_custody", "label": "Collaborative custody" },
            { "value": "business_treasury", "label": "Held by a business" },
            { "value": "ira_retirement", "label": "Inside a retirement account" },
            { "value": "btc_loan_collateral", "label": "Pledged as loan collateral" },
            { "value": "unknown_mixed", "label": "Unknown or mixed" }
          ]
        },
        {
          "id": "cm.who_can_move",
          "section": "custody_map",
          "prompt": "For your largest holding, who can actually move the funds?",
          "type": "single_select",
          "options": [
            { "value": "only_me", "label": "Only me", "flags": ["custody.single_point"] },
            { "value": "me_and_one_other", "label": "Me and one other person" },
            { "value": "multiple", "label": "Several people / a quorum" },
            { "value": "a_provider", "label": "A provider controls it", "flags": ["custody.counterparty"] },
            { "value": "unknown", "label": "I am not sure", "flags": ["custody.unclear"] }
          ]
        },
        {
          "id": "cm.if_unavailable",
          "section": "custody_map",
          "prompt": "If you were unavailable for 60 days, what would happen to that holding?",
          "type": "single_select",
          "options": [
            { "value": "others_can_recover", "label": "Someone could recover it cleanly" },
            { "value": "others_would_struggle", "label": "Someone would struggle but might manage", "flags": ["custody.fragile_recovery"] },
            { "value": "no_one_could", "label": "No one could access it", "flags": ["custody.single_point", "estate.access_gap"] },
            { "value": "unknown", "label": "I do not know", "flags": ["custody.unclear"] }
          ]
        },
        {
          "id": "cm.documented",
          "section": "custody_map",
          "prompt": "Is there a written record of what exists and how it is structured (not the secrets, just the map)?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes, and it is current" },
            { "value": "partially", "label": "Partially", "flags": ["doc.partial"] },
            { "value": "no", "label": "No", "flags": ["doc.missing"] },
            { "value": "unknown", "label": "Not sure", "flags": ["doc.unclear"] }
          ]
        }
      ]
    },
    {
      "section": "tax_visibility",
      "title": "Your tax visibility map",
      "questions": [
        {
          "id": "tv.where_bought",
          "section": "tax_visibility",
          "prompt": "Where did you mostly acquire your Bitcoin?",
          "type": "single_select",
          "options": [
            { "value": "one_country_exchange", "label": "Exchanges in one country" },
            { "value": "multi_country_exchange", "label": "Exchanges in more than one country", "flags": ["tax.multi_jurisdiction"] },
            { "value": "peer_or_cash", "label": "Peer-to-peer or cash", "flags": ["tax.records_thin"] },
            { "value": "mixed", "label": "A mix", "flags": ["tax.records_thin"] },
            { "value": "unknown", "label": "Not sure", "flags": ["tax.unclear"] }
          ]
        },
        {
          "id": "tv.records",
          "section": "tax_visibility",
          "prompt": "How would you describe your cost-basis and transaction records?",
          "type": "single_select",
          "options": [
            { "value": "clear", "label": "Clear and complete" },
            { "value": "partial", "label": "Partial", "flags": ["tax.records_thin"] },
            { "value": "none", "label": "I do not really have them", "flags": ["tax.records_missing"] },
            { "value": "unknown", "label": "Not sure", "flags": ["tax.unclear"] }
          ]
        },
        {
          "id": "tv.events",
          "section": "tax_visibility",
          "prompt": "Which of these have you done? Choose all that apply.",
          "type": "multi_select",
          "options": [
            { "value": "sales", "label": "Sold Bitcoin", "flags": ["tax.taxable_events"] },
            { "value": "swaps", "label": "Traded Bitcoin for another asset", "flags": ["tax.taxable_events"] },
            { "value": "gifts", "label": "Gifted Bitcoin", "flags": ["tax.gifts"] },
            { "value": "loans", "label": "Borrowed against Bitcoin", "flags": ["tax.loans"] },
            { "value": "donations", "label": "Donated Bitcoin", "flags": ["tax.donations"] },
            { "value": "payments", "label": "Paid for things with Bitcoin", "flags": ["tax.payments"] },
            { "value": "none", "label": "None of these" }
          ]
        },
        {
          "id": "tv.exposed_regimes",
          "section": "tax_visibility",
          "prompt": "Are you connected to any country with worldwide taxation, wealth tax, exit tax, inheritance tax, or gift tax?",
          "help_text": "If you are unsure, choose 'not sure'. The country library can help you check.",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes", "flags": ["tax.heavy_regime"] },
            { "value": "no", "label": "No" },
            { "value": "unknown", "label": "Not sure", "flags": ["tax.unclear"] }
          ]
        },
        {
          "id": "tv.advisors",
          "section": "tax_visibility",
          "prompt": "Do you have a tax advisor in each country that taxes you?",
          "type": "single_select",
          "options": [
            { "value": "yes_all", "label": "Yes, in each one" },
            { "value": "some", "label": "In some, not all", "flags": ["advisor.partial_coverage"] },
            { "value": "none", "label": "No", "flags": ["advisor.gap"] },
            { "value": "single_country", "label": "I am only taxed in one country" }
          ]
        }
      ]
    },
    {
      "section": "estate_family",
      "title": "Your estate and family map",
      "questions": [
        {
          "id": "ef.locations",
          "section": "estate_family",
          "prompt": "Are your heirs, spouse, and executor in the same country as you?",
          "type": "single_select",
          "options": [
            { "value": "all_same", "label": "Yes, all in one country" },
            { "value": "spread", "label": "No, spread across countries", "flags": ["family.cross_border"] },
            { "value": "no_plan", "label": "I have not named an executor or heirs", "flags": ["estate.no_plan"] },
            { "value": "unknown", "label": "Not sure", "flags": ["estate.unclear"] }
          ]
        },
        {
          "id": "ef.docs_valid",
          "section": "estate_family",
          "prompt": "Are your legal documents valid and in the right language in each relevant country?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "one_country_only", "label": "Valid in one country only", "flags": ["estate.document_gap"] },
            { "value": "no_docs", "label": "I do not have these documents", "flags": ["estate.no_plan"] },
            { "value": "unknown", "label": "Not sure", "flags": ["estate.unclear"] }
          ]
        },
        {
          "id": "ef.family_aware",
          "section": "estate_family",
          "prompt": "Does anyone in your family know the Bitcoin exists and who to call?",
          "type": "single_select",
          "options": [
            { "value": "yes_and_safe", "label": "Yes, and they could tell a real recovery from a scam" },
            { "value": "yes_not_safe", "label": "Yes, but they could be tricked by a scam", "flags": ["family.scam_risk"] },
            { "value": "no", "label": "No one knows", "flags": ["family.awareness_gap", "estate.access_gap"] },
            { "value": "unknown", "label": "Not sure", "flags": ["estate.unclear"] }
          ]
        },
        {
          "id": "ef.authority_access",
          "section": "estate_family",
          "prompt": "Think about authority versus access. Which is true?",
          "help_text": "Authority is the legal right to act. Access is the technical ability to move the keys. They are often held by different people.",
          "type": "single_select",
          "options": [
            { "value": "aligned", "label": "The person with authority can also access the keys" },
            { "value": "authority_no_access", "label": "Someone has authority but no access", "flags": ["estate.authority_access_mismatch"] },
            { "value": "access_no_authority", "label": "Someone has access but no authority", "flags": ["estate.authority_access_mismatch"] },
            { "value": "one_person", "label": "It all depends on one person", "flags": ["custody.single_point", "estate.single_person"] },
            { "value": "unknown", "label": "Not sure", "flags": ["estate.unclear"] }
          ]
        }
      ]
    },
    {
      "section": "banking_liquidity",
      "title": "Your banking and liquidity map",
      "questions": [
        {
          "id": "bl.banks",
          "section": "banking_liquidity",
          "prompt": "How many banks do you rely on, and in how many countries?",
          "type": "single_select",
          "options": [
            { "value": "one_bank", "label": "One bank", "flags": ["banking.single_point"] },
            { "value": "multi_one_country", "label": "Several banks, one country" },
            { "value": "multi_countries", "label": "Banks in more than one country" },
            { "value": "unknown", "label": "Not sure", "flags": ["banking.unclear"] }
          ]
        },
        {
          "id": "bl.resilience",
          "section": "banking_liquidity",
          "prompt": "If one bank froze or closed your account, could you cover essentials for 90 days?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes, comfortably" },
            { "value": "tight", "label": "It would be tight", "flags": ["banking.fragile"] },
            { "value": "no", "label": "No", "flags": ["banking.fragile"] },
            { "value": "unknown", "label": "Not sure", "flags": ["banking.unclear"] }
          ]
        },
        {
          "id": "bl.single_dependency",
          "section": "banking_liquidity",
          "prompt": "Do you depend on one exchange, one bank, one phone, one email, or one app for moving money?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes", "flags": ["banking.single_point", "device.single_point"] },
            { "value": "no", "label": "No, there is redundancy" },
            { "value": "unknown", "label": "Not sure", "flags": ["banking.unclear"] }
          ]
        }
      ]
    },
    {
      "section": "device_identity",
      "title": "Your device, identity, and platform map",
      "questions": [
        {
          "id": "di.phone_email",
          "section": "device_identity",
          "prompt": "Does one phone number or one email control most of your important accounts?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes", "flags": ["device.single_point"] },
            { "value": "no", "label": "No, they are separated" },
            { "value": "unknown", "label": "Not sure", "flags": ["device.unclear"] }
          ]
        },
        {
          "id": "di.protections",
          "section": "device_identity",
          "prompt": "Which of these do you use? Choose all that apply.",
          "type": "multi_select",
          "options": [
            { "value": "password_manager", "label": "A password manager" },
            { "value": "twofa", "label": "Two-factor authentication" },
            { "value": "hardware_keys", "label": "Hardware security keys" },
            { "value": "none", "label": "None of these", "flags": ["device.weak_protection"] }
          ]
        },
        {
          "id": "di.heir_access",
          "section": "device_identity",
          "prompt": "Could your heirs reach your records (account list, instructions) without you handing over secrets while alive?",
          "type": "single_select",
          "options": [
            { "value": "yes", "label": "Yes, there is a safe path" },
            { "value": "no", "label": "No", "flags": ["estate.access_gap"] },
            { "value": "unknown", "label": "Not sure", "flags": ["estate.unclear"] }
          ]
        }
      ]
    },
    {
      "section": "documentation_paradox",
      "title": "The documentation classifier",
      "questions": [
        {
          "id": "dp.items",
          "section": "documentation_paradox",
          "prompt": "For each item, how do you currently handle it?",
          "help_text": "There is no single right answer. The tool will show a recommended handling class for each item and flag anything that looks like a leak or a gap.",
          "type": "per_item_class",
          "options": [
            { "value": "seed_phrase", "label": "Seed phrase" },
            { "value": "pin", "label": "PIN" },
            { "value": "passphrase", "label": "Passphrase" },
            { "value": "device_location", "label": "Device location" },
            { "value": "metal_backup_location", "label": "Metal backup location" },
            { "value": "wallet_type", "label": "Wallet type" },
            { "value": "exchange_names", "label": "Exchange names" },
            { "value": "custody_provider_name", "label": "Custody provider name" },
            { "value": "xpub", "label": "Extended public key (xpub)" },
            { "value": "multisig_quorum", "label": "Multisig quorum (e.g. 2-of-3)" },
            { "value": "cosigner_names", "label": "Co-signer names" },
            { "value": "emergency_contact", "label": "Emergency contact" },
            { "value": "tax_records", "label": "Tax records" },
            { "value": "purchase_history", "label": "Purchase history" },
            { "value": "beneficiary_instructions", "label": "Beneficiary instructions" },
            { "value": "will_trust_reference", "label": "Will or trust reference" },
            { "value": "recovery_sequence", "label": "Recovery sequence" },
            { "value": "trusted_helper_role", "label": "Trusted helper role" },
            { "value": "advisor_contact", "label": "Advisor contact" }
          ]
        }
      ]
    },
    {
      "section": "business",
      "title": "Business and family-office exposure",
      "questions": [
        {
          "id": "bz.ownership",
          "section": "business",
          "prompt": "How is the entity that holds or touches Bitcoin owned?",
          "type": "single_select",
          "applies_when": { "user_type_any": ["business_family_office"] },
          "options": [
            { "value": "single_owner", "label": "One owner", "flags": ["business.key_person"] },
            { "value": "multi_owner", "label": "Multiple owners" },
            { "value": "holding_structure", "label": "A holding / multi-entity structure", "flags": ["business.structure_complex"] },
            { "value": "unknown", "label": "Not sure", "flags": ["business.unclear"] }
          ]
        },
        {
          "id": "bz.signers",
          "section": "business",
          "prompt": "Is there a written signer-authority and treasury policy for moving Bitcoin?",
          "type": "single_select",
          "applies_when": { "user_type_any": ["business_family_office"] },
          "options": [
            { "value": "yes", "label": "Yes, documented and current" },
            { "value": "informal", "label": "Informal only", "flags": ["business.governance_gap"] },
            { "value": "no", "label": "No", "flags": ["business.governance_gap"] },
            { "value": "unknown", "label": "Not sure", "flags": ["business.unclear"] }
          ]
        },
        {
          "id": "bz.keyperson",
          "section": "business",
          "prompt": "If the main signer left or was unavailable, could the business still operate the treasury?",
          "type": "single_select",
          "applies_when": { "user_type_any": ["business_family_office"] },
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No", "flags": ["business.key_person", "business.governance_gap"] },
            { "value": "unknown", "label": "Not sure", "flags": ["business.unclear"] }
          ]
        }
      ]
    },
    {
      "section": "scenario_stress_test",
      "title": "A short stress test",
      "questions": [
        {
          "id": "ss.bank_freeze",
          "section": "scenario_stress_test",
          "prompt": "A bank freezes your main account tomorrow with no warning. How exposed are you?",
          "type": "single_select",
          "options": [
            { "value": "fine", "label": "I would be fine" },
            { "value": "disrupted", "label": "Disrupted but okay", "flags": ["banking.fragile"] },
            { "value": "serious", "label": "Serious problem", "flags": ["banking.fragile", "banking.single_point"] }
          ]
        },
        {
          "id": "ss.keyholder_gone",
          "section": "scenario_stress_test",
          "prompt": "The person who understands the Bitcoin setup is unreachable for 60 days. What happens?",
          "type": "single_select",
          "options": [
            { "value": "covered", "label": "Others could carry on" },
            { "value": "stalled", "label": "Things would stall", "flags": ["custody.single_point"] },
            { "value": "lost", "label": "Access could be lost", "flags": ["custody.single_point", "estate.access_gap"] }
          ]
        },
        {
          "id": "ss.move_triggers_tax",
          "section": "scenario_stress_test",
          "prompt": "You move to a new country next year. Do you know whether it changes your tax residence or triggers an exit tax?",
          "type": "single_select",
          "applies_when": { "user_type_any": ["considering_relocation", "cross_border_family", "individual_holder"] },
          "options": [
            { "value": "yes", "label": "Yes, I have checked" },
            { "value": "no", "label": "No", "flags": ["mobility.unchecked", "tax.unclear"] },
            { "value": "unknown", "label": "Not sure where to even check", "flags": ["mobility.unchecked"] }
          ]
        }
      ]
    }
  ]
}
