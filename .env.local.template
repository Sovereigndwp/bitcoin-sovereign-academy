# Bitcoin Sovereign Academy - Local API Configuration
# NEVER commit this file to version control

# Supabase Database
# Get these from: https://supabase.com/dashboard -> your project -> Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Core
# IMPORTANT: Generate a NEW secret with: openssl rand -base64 48
# Never reuse this across environments. Rotate if exposed.
JWT_SECRET=GENERATE_WITH__openssl_rand_-base64_48

# Stripe
STRIPE_SECRET=YOUR_NEW_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# BTCPay
BTCPAY_URL=https://your-btcpay.tld
BTCPAY_API_KEY=btcpay_xxx
BTCPAY_STORE_ID=your_store_id
BTCPAY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Alby Hub (Lightning)
# Get your API key from your Alby Hub: Settings > API
ALBY_HUB_URL=https://your-alby-hub.com
ALBY_API_KEY=your_alby_api_key_here
ALBY_WEBHOOK_SECRET=your_webhook_secret

# CORS
ALLOWED_ORIGIN=http://localhost:3000
