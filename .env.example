# Zaprite Payment Integration - Environment Variables
# Copy this file to .env.local (Vercel) or .env (local development)

# Zaprite API Configuration
# Get your API key from: https://app.zaprite.com -> Settings -> API
ZAPRITE_API_KEY=your_zaprite_api_key_here

# Zaprite Webhook Secret (for signature verification)
# Generate this when setting up webhooks in Zaprite dashboard
ZAPRITE_WEBHOOK_SECRET=your_webhook_secret_here

# JWT Secret (for signing access tokens)
# Generate a random string: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Base URL (your domain)
# Production: https://bitcoinsovereign.academy
# Development: http://localhost:3000
BASE_URL=https://bitcoinsovereign.academy

# Node Environment
NODE_ENV=production

# ──────────────────────────────────────────────────────────────
# Nostr publishing (scripts/nostr/*).  See docs/marketing/nostr-playbook.md.
# NEVER commit a real nsec or hex private key. Use .env.local only.
# ──────────────────────────────────────────────────────────────

# Signer selection: env | bunker | dry-run
NOSTR_SIGNER_MODE=env

# Set to 1 to use the TEST account (recommended for the first 7 days).
NOSTR_USE_TEST=1

# Main account (only used when NOSTR_USE_TEST != 1).
# Hex format, lowercase, 64 chars. Do NOT paste an nsec1… string here.
NOSTR_PRIVATE_KEY_HEX=
NOSTR_PUBLIC_KEY_HEX=

# Test account (used when NOSTR_USE_TEST=1).
NOSTR_TEST_PRIVATE_KEY_HEX=
NOSTR_TEST_PUBLIC_KEY_HEX=

# NIP-46 remote signer (used when NOSTR_SIGNER_MODE=bunker).
# Looks like: bunker://<pubkey>?relay=wss://...&secret=...
NOSTR_BUNKER_URI=

# Required for live publishing to MAIN account. Must be the exact string:
# YES_I_REALLY_WANT_TO_PUBLISH_FROM_MAIN
NOSTR_CONFIRM_LIVE=

# Public-facing identifiers (used by the /nostr/ page and scripts).
NOSTR_NIP05=_@bitcoinsovereign.academy
NOSTR_LIGHTNING_ADDRESS=sovereigndwp@getalby.com
BSA_SITE_URL=https://bitcoinsovereign.academy
HUBSPOT_MEETING_URL=https://meetings.hubspot.com/dalia-platt
CONTACT_EMAIL=thesovereign.academy@proton.me
