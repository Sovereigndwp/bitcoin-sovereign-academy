<?xml version="1.0" encoding="UTF-8"?>
<!--
  STUB — square ratio for IG feed / X card.
  Renders the same content with compact layout. Iterate after portrait is approved.
  Layout: header band (15%) → 5-card 2x2+1 grid (55%) → key-lesson (15%) → footer (15%).
-->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1080 1080" width="1080" height="1080">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#000000"/>
      <stop offset="100%" stop-color="#1a1a1a"/>
    </linearGradient>
    <linearGradient id="orangeBand" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#f7931a"/>
      <stop offset="100%" stop-color="#facc15"/>
    </linearGradient>
    <style>
      text { font-family: "Helvetica Neue", "Inter", "Segoe UI", Arial, sans-serif; }
      .stub { font-size: 24px; fill: #f7931a; font-weight: 700; }
    </style>
  </defs>
  <rect width="1080" height="1080" fill="url(#bg)"/>
  <rect x="0" y="0" width="1080" height="3" fill="url(#orangeBand)"/>
  <text x="540" y="540" text-anchor="middle" class="stub">SQUARE STUB — {{title}}</text>
  <text x="540" y="580" text-anchor="middle" font-family="Helvetica Neue,Arial,sans-serif" font-size="14" fill="#888">Iterate after portrait approval.</text>
  <g transform="translate(40, 1024) scale(0.20)">{{{logoInner}}}</g>
  <text x="84" y="1042" font-family="Helvetica Neue,Arial,sans-serif" font-size="12" fill="#888" letter-spacing="1.5">{{footer}}</text>
</svg>
