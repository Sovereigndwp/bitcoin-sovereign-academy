<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1080 1080" width="1080" height="1080">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#000000"/>
      <stop offset="100%" stop-color="#1a1a1a"/>
    </linearGradient>
    <linearGradient id="orangeBand" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#f7931a"/>
      <stop offset="100%" stop-color="#facc15"/>
    </linearGradient>
    <linearGradient id="cardGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#181818"/>
      <stop offset="100%" stop-color="#101010"/>
    </linearGradient>
    <style>
      text { font-family: "Helvetica Neue", "Inter", "Segoe UI", Arial, sans-serif; }
      .tag { font-size: 18px; font-weight: 700; letter-spacing: 4px; fill: #f7931a; }
      .title { font-weight: 900; letter-spacing: 1px; fill: #ffffff; }
      .subtitle { font-size: 22px; font-style: italic; fill: #facc15; }
      .arc-chip { font-size: 17px; font-weight: 700; fill: #ffffff; letter-spacing: 1px; }
      .arc-cap { font-size: 14px; font-style: italic; fill: #aaa; }
      .row-name { font-size: 19px; font-weight: 700; fill: #f7931a; }
      .row-does { font-size: 14px; fill: #ddd; }
      .row-num { font-size: 22px; font-weight: 900; fill: #1a1a1a; }
      .key-lesson { font-size: 22px; font-weight: 800; fill: #1a1a1a; letter-spacing: 0.5px; }
      .footer { font-size: 12px; fill: #888; letter-spacing: 1.5px; }
    </style>
  </defs>

  <rect width="1080" height="1080" fill="url(#bg)"/>
  <rect x="0" y="0" width="1080" height="3" fill="url(#orangeBand)"/>

  <!-- Header -->
  <text x="60" y="58" class="tag">{{tag}}</text>
  {{#each titleLines}}
  <text x="60" y="{{y}}" class="title" font-size="{{../titleFontSize}}">{{text}}</text>
  {{/each}}
  {{#each subtitleLines}}
  <text x="60" y="{{y}}" class="subtitle">{{text}}</text>
  {{/each}}

  <!-- Arc as hero -->
  <g transform="translate(0, {{arcY}})">
    {{#each arcChips}}
    <g transform="translate({{x}}, 0)">
      <rect width="{{w}}" height="48" rx="24" fill="rgba(247,147,26,0.12)" stroke="#f7931a" stroke-width="2"/>
      <text x="{{cx}}" y="31" text-anchor="middle" class="arc-chip">{{label}}</text>
    </g>
    {{/each}}
    {{#each arcArrows}}
    <line x1="{{x1}}" y1="24" x2="{{x2}}" y2="24" stroke="#f7931a" stroke-width="2.5"/>
    <polygon points="{{x2}},24 {{ax}},18 {{ax}},30" fill="#f7931a"/>
    {{/each}}
  </g>

  <!-- 5 compact rows: number · name · does (single line) -->
  {{#each components}}
  <g transform="translate(60, {{row_y}})">
    <rect width="960" height="74" rx="12" fill="url(#cardGrad)" stroke="#252525" stroke-width="1"/>
    <circle cx="38" cy="37" r="22" fill="url(#orangeBand)"/>
    <text x="38" y="45" text-anchor="middle" class="row-num">{{n}}</text>
    <text x="78" y="32" class="row-name">{{name}}</text>
    {{#each does_lines}}
    <text x="78" y="{{y}}" class="row-does">{{text}}</text>
    {{/each}}
  </g>
  {{/each}}

  <!-- Key lesson band -->
  <g transform="translate(0, {{keyY}})">
    <rect width="1080" height="60" fill="url(#orangeBand)"/>
    <text x="540" y="38" text-anchor="middle" class="key-lesson">{{key_lesson}}</text>
  </g>

  <!-- Footer with logo -->
  <g transform="translate(60, {{footerY}})">
    <g transform="translate(0, 4) scale(0.20)">{{{logoInner}}}</g>
    <text x="44" y="22" class="footer">{{footer}}</text>
  </g>
</svg>
