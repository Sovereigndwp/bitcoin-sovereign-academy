<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 627" width="1200" height="627">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#000000"/>
      <stop offset="100%" stop-color="#1a1a1a"/>
    </linearGradient>
    <linearGradient id="orangeBand" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#f7931a"/>
      <stop offset="100%" stop-color="#facc15"/>
    </linearGradient>
    <style>
      text { font-family: "Helvetica Neue", "Inter", "Segoe UI", Arial, sans-serif; }
      .tag { font-size: 16px; font-weight: 700; letter-spacing: 4px; fill: #f7931a; }
      .title { font-weight: 900; letter-spacing: 1px; fill: #ffffff; }
      .subtitle { font-size: 19px; font-style: italic; fill: #facc15; }
      .arc-chip { font-size: 14px; font-weight: 700; fill: #ffffff; letter-spacing: 1px; }
      .key-lesson { font-size: 18px; font-weight: 800; fill: #1a1a1a; }
      .footer { font-size: 12px; fill: #888; letter-spacing: 1.5px; }
    </style>
  </defs>

  <rect width="1200" height="627" fill="url(#bg)"/>
  <rect x="0" y="0" width="1200" height="3" fill="url(#orangeBand)"/>

  <!-- Header -->
  <text x="60" y="56" class="tag">{{tag}}</text>
  {{#each titleLines}}
  <text x="60" y="{{y}}" class="title" font-size="{{../titleFontSize}}">{{text}}</text>
  {{/each}}
  {{#each subtitleLines}}
  <text x="60" y="{{y}}" class="subtitle">{{text}}</text>
  {{/each}}

  <!-- Arc as hero (centered) -->
  <g transform="translate(0, {{arcY}})">
    {{#each arcChips}}
    <g transform="translate({{x}}, 0)">
      <rect width="{{w}}" height="44" rx="22" fill="rgba(247,147,26,0.14)" stroke="#f7931a" stroke-width="2"/>
      <text x="{{cx}}" y="29" text-anchor="middle" class="arc-chip">{{label}}</text>
    </g>
    {{/each}}
    {{#each arcArrows}}
    <line x1="{{x1}}" y1="22" x2="{{x2}}" y2="22" stroke="#f7931a" stroke-width="2"/>
    <polygon points="{{x2}},22 {{ax}},16 {{ax}},28" fill="#f7931a"/>
    {{/each}}
  </g>

  <!-- Key lesson band -->
  <g transform="translate(0, {{keyY}})">
    <rect width="1200" height="48" fill="url(#orangeBand)"/>
    <text x="600" y="31" text-anchor="middle" class="key-lesson">{{key_lesson}}</text>
  </g>

  <!-- Footer with logo -->
  <g transform="translate(60, {{footerY}})">
    <g transform="translate(0, 4) scale(0.18)">{{{logoInner}}}</g>
    <text x="40" y="20" class="footer">{{footer}}</text>
  </g>
</svg>
