<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1536" width="1024" height="1536">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#000000"/>
      <stop offset="100%" stop-color="#1a1a1a"/>
    </linearGradient>
    <linearGradient id="orangeBand" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#f7931a"/>
      <stop offset="100%" stop-color="#facc15"/>
    </linearGradient>
    <linearGradient id="cardGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#181818"/>
      <stop offset="100%" stop-color="#101010"/>
    </linearGradient>
    <style>
      text { font-family: "Helvetica Neue", "Inter", "Segoe UI", Arial, sans-serif; }
      .tag { font-size: 18px; font-weight: 700; letter-spacing: 4px; fill: #f7931a; }
      .title { font-size: 50px; font-weight: 900; letter-spacing: 1px; fill: #ffffff; }
      .subtitle { font-size: 22px; font-style: italic; fill: #facc15; }
      .lead { font-size: 17px; fill: #cfcfcf; }
      .card-name { font-size: 22px; font-weight: 700; fill: #f7931a; }
      .card-abbrev { font-size: 11px; font-weight: 700; letter-spacing: 2px; fill: #888; }
      .card-does { font-size: 14px; fill: #ececec; }
      .card-fails { font-size: 12px; fill: #ef6b6b; }
      .card-num { font-size: 30px; font-weight: 900; fill: #1a1a1a; }
      .arc-chip { font-size: 14px; font-weight: 700; fill: #ffffff; letter-spacing: 1px; }
      .arc-cap { font-size: 13px; font-style: italic; fill: #aaaaaa; }
      .miscon-head { font-size: 13px; font-weight: 700; letter-spacing: 4px; fill: #888; }
      .miscon-wrong { font-size: 14px; font-style: italic; fill: #ef4444; }
      .miscon-better { font-size: 14px; fill: #dddddd; }
      .miscon-mark { font-size: 16px; font-weight: 900; }
      .key-lesson { font-size: 22px; font-weight: 800; fill: #1a1a1a; letter-spacing: 0.5px; }
      .footer { font-size: 12px; fill: #888; letter-spacing: 1.5px; }
      .ill-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; fill: #555; }
      .ill-id { font-size: 8px; fill: #444; }
    </style>
  </defs>

  <rect width="1024" height="1536" fill="url(#bg)"/>

  <!-- Header band -->
  <rect x="0" y="0" width="1024" height="3" fill="url(#orangeBand)"/>
  <text x="60" y="62" class="tag">{{tag}}</text>

  {{#each titleLines}}
  <text x="60" y="{{y}}" class="title">{{text}}</text>
  {{/each}}

  {{#each subtitleLines}}
  <text x="60" y="{{y}}" class="subtitle">{{text}}</text>
  {{/each}}

  {{#each leadLines}}
  <text x="60" y="{{y}}" class="lead">{{text}}</text>
  {{/each}}

  <line x1="60" y1="{{dividerY}}" x2="964" y2="{{dividerY}}" stroke="#2a2a2a" stroke-width="1"/>

  <!-- 5 component cards: number · illustration · text -->
  {{#each components}}
  <g transform="translate(60, {{card_y}})">
    <rect width="904" height="{{../cardH}}" rx="14" fill="url(#cardGrad)" stroke="#2a2a2a" stroke-width="1"/>

    <!-- Numbered orange disc (far left) -->
    <circle cx="58" cy="{{../cardCY}}" r="30" fill="url(#orangeBand)"/>
    <text x="58" y="{{../cardNumY}}" text-anchor="middle" class="card-num">{{n}}</text>

    <!-- Illustration (left of text, 100x100) -->
    <g transform="translate({{../illX}}, {{../illY}})">
      <rect width="{{../illSize}}" height="{{../illSize}}" rx="12" fill="#0a0a0a" stroke="#333" stroke-width="1" stroke-dasharray="4 4"/>
      <text x="50" y="48" text-anchor="middle" class="ill-label">ILL</text>
      <text x="50" y="66" text-anchor="middle" class="ill-id">{{illustration_id}}</text>
    </g>

    <!-- Text -->
    <text x="{{../textX}}" y="36" class="card-name">{{name}}</text>
    <text x="{{../textX}}" y="55" class="card-abbrev">{{abbrev}}</text>
    {{#each does_lines}}
    <text x="{{../../textX}}" y="{{y}}" class="card-does">{{text}}</text>
    {{/each}}
    {{#each if_fails_lines}}
    <text x="{{../../textX}}" y="{{y}}" class="card-fails">{{#if first}}If it fails: {{/if}}{{text}}</text>
    {{/each}}
  </g>
  {{/each}}

  <!-- Derivation arc -->
  <g transform="translate(0, {{arcY}})">
    {{#each arcChips}}
    <g transform="translate({{x}}, 0)">
      <rect width="{{w}}" height="40" rx="20" fill="rgba(247,147,26,0.12)" stroke="#f7931a" stroke-width="1.5"/>
      <text x="{{cx}}" y="26" text-anchor="middle" class="arc-chip">{{label}}</text>
    </g>
    {{/each}}
    {{#each arcArrows}}
    <line x1="{{x1}}" y1="20" x2="{{x2}}" y2="20" stroke="#f7931a" stroke-width="2"/>
    <polygon points="{{x2}},20 {{ax}},14 {{ax}},26" fill="#f7931a"/>
    {{/each}}
  </g>

  {{#each arcCaptionLines}}
  <text x="512" y="{{y}}" text-anchor="middle" class="arc-cap">{{text}}</text>
  {{/each}}

  <!-- Misconceptions -->
  <text x="60" y="{{misconHeaderY}}" class="miscon-head">COMMON MISCONCEPTIONS</text>
  {{#each misconceptions}}
  <g transform="translate(60, {{y}})">
    <text x="0" y="14" class="miscon-mark" fill="#ef4444">✗</text>
    <text x="22" y="14" class="miscon-wrong">"{{wrong}}"</text>
    <text x="0" y="36" class="miscon-mark" fill="#22c55e">✓</text>
    {{#each better_lines}}
    <text x="22" y="{{y}}" class="miscon-better">{{text}}</text>
    {{/each}}
  </g>
  {{/each}}

  <!-- Key lesson band -->
  <g transform="translate(0, {{keyY}})">
    <rect width="1024" height="60" fill="url(#orangeBand)"/>
    <text x="512" y="38" text-anchor="middle" class="key-lesson">{{key_lesson}}</text>
  </g>

  <!-- Footer with logo -->
  <g transform="translate(60, {{footerY}})">
    <g transform="translate(0, 4) scale(0.20)">
      {{{logoInner}}}
    </g>
    <text x="44" y="22" class="footer">{{footer}}</text>
  </g>
</svg>
